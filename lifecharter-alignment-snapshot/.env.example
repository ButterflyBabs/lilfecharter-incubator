# LifeCharter Alignment Snapshot - Environment Variables
# Copy this file to .env.local and fill in your actual values

# ============================================
# REQUIRED: OpenAI API Key for AI report generation
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# REQUIRED: Email Service (Resend)
# Get from: https://resend.com
RESEND_API_KEY=re_your-resend-api-key
FROM_EMAIL=babs@amilynnecarroll.com

# ============================================
# REQUIRED: Global Control CRM Integration
# Get from your Global Control CRM dashboard
GLOBAL_CONTROL_API_KEY=your-global-control-api-key
GLOBAL_CONTROL_API_URL=https://api.globalcontrolcrm.com/v1

# ============================================
# OPTIONAL: Workflow Automation IDs
# Configure these in Global Control to trigger nurture sequences
WORKFLOW_SUMMIT_ID=your-summit-workflow-id
WORKFLOW_INCUBATOR_ID=your-incubator-workflow-id
WORKFLOW_CIRCLE_ID=your-circle-workflow-id
WORKFLOW_CONVERSATION_ID=your-conversation-workflow-id

# ============================================
# OPTIONAL: Custom domain for CTA links
NEXT_PUBLIC_DOMAIN=https://amilynnecarroll.com